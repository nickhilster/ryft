    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    padding: 4px 10px;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: var(--accent-bg);
  }

  .section-header h2 {
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.8px;
  }

  .section-sub {
    font-size: 17px;
    color: var(--text);
    line-height: 1.65;
  }

  /* ══ Flow steps (how it works) ════════════════════════════════════════════ */
  .flow-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
    margin: 0 auto 48px;
  }

  .flow-step {
    display: grid;
    grid-template-columns: 48px 1fr 64px;
    gap: 24px;
    align-items: start;
    padding: 32px 24px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    position: relative;
  }

  .flow-step:not(:last-child) {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom: none;
  }

  .flow-step + .flow-connector + .flow-step {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .step-num {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.5px;
    margin-top: 4px;
  }

  .step-body h3 {
    font-size: 18px;
    margin-bottom: 8px;
  }

  .step-body p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
  }

  .step-body strong { color: var(--text-h); }

  .step-tag {
    margin-top: 12px;
  }

  .mono-tag {
    font-family: var(--mono);
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    color: var(--accent);
  }

  .step-code-block {
    margin-top: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    background: var(--code-bg);
    border: 1px solid var(--border);
  }

  .step-code-block code {
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-h);
  }

  .step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text);
    flex-shrink: 0;
  }

  .accent-icon { border-color: var(--accent-border); background: var(--accent-bg); color: var(--accent); }
  .ok-icon     { border-color: rgba(70,217,138,0.3); background: rgba(70,217,138,0.08); color: var(--ok); }

  .flow-connector {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 32px;
    max-width: 760px;
    margin: 0 auto;
  }

  .connector-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border) 0%, var(--accent-border) 50%, var(--border) 100%);
  }

  .connector-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text);
    opacity: 0.55;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Token budget card */
  .budget-card {
    max-width: 760px;
    margin: 0 auto;
    padding: 16px 20px;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .budget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .budget-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-h);
  }

  .budget-chip {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .safe-chip {
    color: var(--ok);
    border-color: rgba(70,217,138,0.3);
    background: rgba(70,217,138,0.08);
  }

  .budget-track {
    height: 8px;
    border-radius: 999px;
    background: var(--bg);
    overflow: hidden;
  }

  .budget-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s;
  }

  .safe-fill { background: linear-gradient(90deg, var(--ok), #10b981); }

  .budget-breakdown {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    opacity: 0.7;
  }

  .budget-note {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
  }

  /* ══ Safety grid ══════════════════════════════════════════════════════════ */
  .safety-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    max-width: 1020px;
    margin: 0 auto;
  }

  .safety-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    transition: border-color 0.2s;
  }

  .safety-card:hover { border-color: var(--border-strong); }

  .accent-safety {
    border-color: var(--accent-border);
    background: color-mix(in srgb, var(--accent-bg) 60%, var(--surface));
  }

  .safety-icon {
    color: var(--text);
    opacity: 0.7;
  }

  .accent-safety .safety-icon { color: var(--accent); opacity: 1; }

  .safety-card h3 {
    font-size: 16px;
  }

  .safety-card h3 code {
    font-size: 14px;
    color: var(--accent);
    background: var(--accent-bg);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .safety-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
  }

  .safety-card p code {
    font-size: 12px;
    color: var(--text-h);
    background: var(--code-bg);
    padding: 1px 5px;
    border-radius: 4px;
  }

  .safety-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--accent-ink);
    font-size: 11px;
    font-weight: 700;
    width: fit-content;
  }

  /* ══ Features grid ════════════════════════════════════════════════════════ */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .wide-card {
    grid-column: span 3;
  }

  .feature-card-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .feature-meta { display: flex; flex-direction: column; gap: 10px; }

  .feature-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--accent);
  }

  .feature-card h3 {
    font-size: 20px;
    letter-spacing: -0.3px;
  }

  .feature-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
  }

  .feature-bullets {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 16px;
    list-style: disc;
  }

  .feature-bullets li {
    font-size: 13px;
    color: var(--text);
    line-height: 1.5;
  }

  /* Repo context visual */
  .feature-visual {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface-2);
  }

  .context-file {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .context-file.included {
    border-color: var(--accent-border);
    background: color-mix(in srgb, var(--accent-bg) 50%, var(--surface));
  }

  .file-check { color: var(--ok); font-size: 12px; font-weight: 700; }
  .file-uncheck { color: var(--text); opacity: 0.4; font-size: 12px; }
  .mono-sm { font-family: var(--mono); font-size: 12px; color: var(--text-h); flex: 1; }
  .file-size { font-family: var(--mono); font-size: 11px; color: var(--text); opacity: 0.55; }

  .context-summary { margin-top: 4px; }
  .summary-chip {
    display: inline-flex;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--mono);
  }

  /* A/B visual */
  .ab-visual {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    margin-top: 8px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-2);
    height: 100px;
  }

  .ab-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    height: 100%;
    justify-content: flex-end;
  }

  .ab-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text);
    opacity: 0.6;
  }

  .selected-label { color: var(--accent); opacity: 1; }

  .ab-bar {
    width: 100%;
    border-radius: 6px 6px 0 0;
    background: var(--border-strong);
  }

  .selected-bar { background: var(--accent); }

  .ab-vs {
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding-bottom: 8px;
    flex-shrink: 0;
  }

  /* Project memory visual */
  .memory-visual {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 8px;
  }

  .memory-entry {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }

  .active-entry {
    border-color: var(--accent-border);
    background: color-mix(in srgb, var(--accent-bg) 50%, var(--surface));
  }

  .memory-label {
    font-size: 12px;
    color: var(--text);
    flex: 1;
    font-family: var(--mono);
  }

  .memory-arrow { font-size: 12px; color: var(--text); opacity: 0.5; }
  .accent-arrow { color: var(--accent); opacity: 1; }

  .memory-chip {
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .accent-chip {
    background: var(--accent);
    border-color: transparent;
    color: var(--accent-ink);
  }

  /* Library visual */
  .library-visual {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .lib-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-2);
  }

  .lib-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-h);
  }

  .lib-tags {
    display: flex;
    gap: 4px;
  }

  .lib-tag {
    padding: 2px 7px;
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent);
    font-size: 11px;
    font-weight: 600;
  }

  /* Agent pills */
  .agent-pills-visual {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .agent-pill {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text);
  }

  .active-agent {
    border-color: var(--accent-border);
    background: var(--accent-bg);
    color: var(--accent);
  }

  /* Image pill */
  .image-pill-visual {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-2);
  }

  .img-thumb-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    flex-shrink: 0;
  }

  .img-meta-sm {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .size-sm {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    opacity: 0.55;
  }

  /* ══ CTA ══════════════════════════════════════════════════════════════════ */
  .cta-section {
    position: relative;
    padding: 100px 40px;
    text-align: center;
    overflow: hidden;
    border-top: 1px solid var(--border);
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(60% 80% at 50% 110%, rgba(200,247,80,0.10) 0%, transparent 70%);
  }

  .cta-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: clamp(32px, 5vw, 52px);
    letter-spacing: -1px;
  }

  .cta-content > p {
    font-size: 17px;
    color: var(--text);
    line-height: 1.65;
  }

  .cta-steps {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-step {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-h);
  }

  .cta-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    font-family: var(--mono);
    flex-shrink: 0;
  }

  .cta-divider {
    color: var(--text);
    opacity: 0.4;
    font-size: 16px;
  }

  .cta-note {
    font-size: 12px;
    color: var(--text);
    opacity: 0.65;
  }

  /* ══ Footer ═══════════════════════════════════════════════════════════════ */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 28px 40px;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: var(--display);
    font-weight: 800;
    font-size: 16px;
    color: var(--text-h);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: auto;
  }

  .footer-links {
    display: flex;
    gap: 16px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--text);
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--text-h); }

  .footer-note {
    font-size: 12px;
    color: var(--text);
    opacity: 0.55;
  }

  /* ══ Animations ═══════════════════════════════════════════════════════════ */
  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.6; transform: scale(0.85); }
  }

  @keyframes conduit {
    0%   { background-position: 0 -100%; }
    100% { background-position: 0 100%; }
  }

  /* Browser AI provider pill — accent-bordered to stand out */
  .browser-ai-pill {
    border-color: var(--accent-border);
    background: var(--accent-bg);
    color: var(--accent);
  }

  /* Iterative refinement visual */
  .adjust-visual {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }

  .adjust-line {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }

  .active-adjust {
    border-color: var(--accent-border);
    background: color-mix(in srgb, var(--accent-bg) 50%, var(--surface));
  }

  .adjust-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    flex-shrink: 0;
  }

  .accent-adjust-badge {
    background: var(--accent);
    border-color: transparent;
    color: var(--accent-ink);
  }

  .adjust-text {
    font-size: 12px;
    color: var(--text);
    font-family: var(--mono);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .adjust-arrow {
    font-size: 11px;
    color: var(--accent);
    padding: 2px 10px;
    opacity: 0.7;
  }

  /* ══ Why RyFine section ══════════════════════════════════════════════════ */
  .why-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
    position: relative;
    overflow: hidden;
  }

  /* Faint radial glow behind the section */
  .why-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(70% 50% at 50% 60%, rgba(200,247,80,0.055) 0%, transparent 70%);
  }

  /* ── Flow diagram ─────────────────────────────────────────────────────── */
  .why-flow {
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 1000px;
    margin: 0 auto 72px;
    padding: 36px 40px;
    border: 1px solid var(--border-strong);
    border-radius: 20px;
    background: var(--surface);
    position: relative;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }

  /* Nodes */
  .why-node {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
  }

  .why-node-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: var(--text);
    opacity: 0.5;
  }

  /* Input node */
  .why-node-input { width: 196px; }

  .why-prompt-snap {
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-2);
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text);
    line-height: 1.55;
    font-style: italic;
  }

  /* RyFine center node */
  .why-node-rf {
    align-items: center;
    text-align: center;
    padding: 22px 24px;
    border: 1px solid var(--accent-border);
    border-radius: 16px;
    background: color-mix(in srgb, var(--accent-bg) 70%, var(--surface));
    position: relative;
    flex-shrink: 0;
    width: 160px;
    box-shadow:
      0 0 0 1px rgba(200,247,80,0.12),
      0 8px 32px rgba(200,247,80,0.12),
      inset 0 1px 0 rgba(200,247,80,0.08);
  }

  .why-rf-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(50% 50% at 50% 50%, rgba(200,247,80,0.14) 0%, transparent 70%);
    pointer-events: none;
    animation: why-glow-breathe 3s ease-in-out infinite;
  }

  @keyframes why-glow-breathe {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.08); }
  }

  .why-rf-logo {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 6px var(--accent-glow));
  }

  .why-rf-name {
    font-family: var(--display);
    font-weight: 800;
    font-size: 15px;
    color: var(--text-h);
    letter-spacing: -0.2px;
    position: relative;
    z-index: 1;
  }

